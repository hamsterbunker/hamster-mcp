# Copy to .env only for local testing. In production, set these in your MCP
# client config (Claude Desktop / Claude Code), not in a committed file.

# Robinhood Chain wallet that signs launches. Needs ~0.0015 ETH for gas.
# NEVER commit a real key. NEVER paste it into chat.
WALLET_PRIVATE_KEY=0x...

# Optional: override the config source (defaults to the live HamsterBunker site).
# HAMSTER_CONFIG_URL=https://hamsterbunker.com/assets/hamster-token.json
